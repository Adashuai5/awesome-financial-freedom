{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Awesome Financial Freedom Knowledge Node",
  "type": "object",
  "required": [
    "id",
    "title",
    "chapter",
    "tags",
    "question_patterns",
    "answer",
    "action_item",
    "related_nodes",
    "source"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string"
    },
    "chapter": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z-]+$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "question_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "answer": {
      "type": "object",
      "required": [
        "summary",
        "core_concept",
        "formula",
        "example",
        "limitations"
      ],
      "properties": {
        "summary": { "type": "string" },
        "core_concept": { "type": "string" },
        "formula": { "type": "string" },
        "example": {
          "type": "object",
          "required": ["scenario", "calculation", "explanation"],
          "properties": {
            "scenario": { "type": "string" },
            "calculation": { "type": "string" },
            "explanation": { "type": "string" }
          }
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "action_item": { "type": "string" },
    "related_nodes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": {
      "type": "object",
      "required": ["primary", "books"],
      "properties": {
        "primary": { "type": "string" },
        "books": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
