{
  "fire_assessment_form": {
    "title": "FIRE 财务自由评估表",
    "description": "获取个性化的财务自由评估和达成时间预测",
    "sections": [
      {
        "id": "basic_info",
        "title": "基本信息",
        "fields": [
          {
            "id": "total_assets",
            "label": "当前总资产",
            "type": "currency",
            "placeholder": "¥",
            "required": true,
            "tooltip": "包括银行存款、投资账户、房产等所有资产总和",
            "validation": {
              "min": 0,
              "type": "number"
            }
          },
          {
            "id": "total_liabilities",
            "label": "总负债（含房贷）",
            "type": "currency",
            "placeholder": "¥",
            "required": true,
            "tooltip": "包括房贷、车贷、信用卡债等所有负债总和",
            "validation": {
              "min": 0,
              "type": "number"
            }
          },
          {
            "id": "primary_residence_value",
            "label": "自住房价值",
            "type": "currency",
            "placeholder": "¥",
            "required": false,
            "tooltip": "家庭唯一住房的市场价值（不包含投资性房产）",
            "validation": {
              "min": 0,
              "type": "number"
            }
          }
        ]
      },
      {
        "id": "expenses_income",
        "title": "收支情况",
        "fields": [
          {
            "id": "annual_fixed_expenses",
            "label": "年固定支出",
            "type": "currency",
            "placeholder": "¥",
            "required": true,
            "tooltip": "生活费、房贷、保险等必需支出的年总和",
            "validation": {
              "min": 0,
              "type": "number"
            }
          },
          {
            "id": "annual_savings",
            "label": "年储蓄能力",
            "type": "currency",
            "placeholder": "¥",
            "required": true,
            "tooltip": "每年可用于投资的金额（税后收入 - 支出）",
            "validation": {
              "min": 0,
              "type": "number"
            }
          },
          {
            "id": "monthly_passive_income",
            "label": "月被动收入",
            "type": "currency",
            "placeholder": "¥",
            "required": false,
            "tooltip": "租金、分红、利息等每月被动收入（可选）",
            "validation": {
              "min": 0,
              "type": "number"
            }
          }
        ]
      },
      {
        "id": "property_debt",
        "title": "房产与负债",
        "fields": [
          {
            "id": "mortgage_balance",
            "label": "房贷余额",
            "type": "currency",
            "placeholder": "¥",
            "required": false,
            "tooltip": "仍需偿还的房贷金额",
            "validation": {
              "min": 0,
              "type": "number"
            }
          },
          {
            "id": "monthly_mortgage_payment",
            "label": "房贷月供",
            "type": "currency",
            "placeholder": "¥",
            "required": false,
            "tooltip": "每月需要偿还的房贷金额",
            "validation": {
              "min": 0,
              "type": "number"
            }
          },
          {
            "id": "mortgage_rate",
            "label": "房贷利率(%)",
            "type": "percentage",
            "placeholder": "3.5",
            "required": false,
            "tooltip": "当前房贷年利率（例如 3.5%）",
            "validation": {
              "min": 0,
              "max": 100,
              "type": "number"
            }
          },
          {
            "id": "other_liabilities",
            "label": "其他负债",
            "type": "currency",
            "placeholder": "¥",
            "required": false,
            "tooltip": "车贷、信用卡等其他负债总额",
            "validation": {
              "min": 0,
              "type": "number"
            }
          }
        ]
      },
      {
        "id": "family_info",
        "title": "家庭信息",
        "fields": [
          {
            "id": "family_status",
            "label": "家庭状况",
            "type": "select",
            "required": true,
            "tooltip": "用于计算应急金额度",
            "options": [
              { "value": "single", "label": "单身（6个月应急金）" },
              { "value": "married", "label": "已婚无子女（9个月应急金）" },
              {
                "value": "with_dependents",
                "label": "有子女/需赡养（12个月应急金）"
              }
            ]
          },
          {
            "id": "dependents_count",
            "label": "赡养人数",
            "type": "number",
            "placeholder": "0",
            "required": false,
            "tooltip": "需要赡养的家庭成员数量",
            "validation": {
              "min": 0,
              "max": 10,
              "type": "number"
            }
          }
        ]
      },
      {
        "id": "investment_preferences",
        "title": "投资偏好",
        "fields": [
          {
            "id": "risk_tolerance",
            "label": "风险承受能力",
            "type": "select",
            "required": true,
            "tooltip": "影响推荐的资产配置和预期收益率",
            "options": [
              { "value": "low", "label": "低风险（债券为主，预期5%年化）" },
              { "value": "medium", "label": "中风险（均衡配置，预期7%年化）" },
              { "value": "high", "label": "高风险（股票为主，预期9%年化）" }
            ]
          },
          {
            "id": "expected_return_rate",
            "label": "预期年化收益率(%)",
            "type": "percentage",
            "placeholder": "7",
            "required": false,
            "tooltip": "基于风险偏好的年化回报率预期（系统会自动填充）",
            "validation": {
              "min": 0,
              "max": 100,
              "type": "number"
            }
          },
          {
            "id": "current_allocation",
            "label": "当前资产配置",
            "type": "text",
            "placeholder": "例如：70% 股票, 30% 债券",
            "required": false,
            "tooltip": "当前投资组合的资产分配比例（可选）"
          }
        ]
      }
    ]
  },
  "dca_planning_form": {
    "title": "定投（DCA）计划",
    "description": "获取个性化的定投策略和风险评估",
    "sections": [
      {
        "id": "investment_plan",
        "title": "投资计划",
        "fields": [
          {
            "id": "monthly_investment",
            "label": "月投资金额",
            "type": "currency",
            "placeholder": "¥",
            "required": true,
            "tooltip": "每月固定投资金额",
            "validation": {
              "min": 100,
              "type": "number"
            }
          },
          {
            "id": "investment_target",
            "label": "投资目标金额",
            "type": "currency",
            "placeholder": "¥",
            "required": true,
            "tooltip": "希望通过定投达到的总资产目标",
            "validation": {
              "min": 1000,
              "type": "number"
            }
          },
          {
            "id": "investment_duration",
            "label": "投资周期（年）",
            "type": "number",
            "placeholder": "10",
            "required": true,
            "tooltip": "计划坚持定投多少年",
            "validation": {
              "min": 1,
              "max": 50,
              "type": "number"
            }
          },
          {
            "id": "dca_asset_type",
            "label": "投资品类",
            "type": "select",
            "required": true,
            "tooltip": "定投的资产类型",
            "options": [
              { "value": "index_fund", "label": "指数基金" },
              { "value": "etf", "label": "ETF（交易型基金）" },
              { "value": "stock", "label": "个股" },
              { "value": "mixed", "label": "混合投资" }
            ]
          }
        ]
      }
    ]
  },
  "rebalancing_form": {
    "title": "资产再平衡",
    "description": "评估投资组合是否需要重新调整",
    "sections": [
      {
        "id": "current_portfolio",
        "title": "当前投资组合",
        "fields": [
          {
            "id": "current_stock_allocation",
            "label": "当前股票配置比例(%)",
            "type": "percentage",
            "placeholder": "70",
            "required": true,
            "tooltip": "当前权益类资产占比",
            "validation": {
              "min": 0,
              "max": 100,
              "type": "number"
            }
          },
          {
            "id": "current_bond_allocation",
            "label": "当前债券配置比例(%)",
            "type": "percentage",
            "placeholder": "30",
            "required": true,
            "tooltip": "当前固定收益资产占比（应与股票占比之和=100%）",
            "validation": {
              "min": 0,
              "max": 100,
              "type": "number"
            }
          },
          {
            "id": "portfolio_total_value",
            "label": "投资组合总资产",
            "type": "currency",
            "placeholder": "¥",
            "required": true,
            "tooltip": "当前投资组合的总市值",
            "validation": {
              "min": 0,
              "type": "number"
            }
          },
          {
            "id": "target_stock_allocation",
            "label": "目标股票配置比例(%)",
            "type": "percentage",
            "placeholder": "60",
            "required": true,
            "tooltip": "希望达到的股票配置比例",
            "validation": {
              "min": 0,
              "max": 100,
              "type": "number"
            }
          },
          {
            "id": "target_bond_allocation",
            "label": "目标债券配置比例(%)",
            "type": "percentage",
            "placeholder": "40",
            "required": true,
            "tooltip": "希望达到的债券配置比例（应与目标股票占比之和=100%）",
            "validation": {
              "min": 0,
              "max": 100,
              "type": "number"
            }
          }
        ]
      },
      {
        "id": "rebalancing_options",
        "title": "再平衡选项",
        "fields": [
          {
            "id": "rebalancing_frequency",
            "label": "再平衡频率",
            "type": "select",
            "required": true,
            "tooltip": "建议的再平衡周期",
            "options": [
              { "value": "quarterly", "label": "季度（每3个月）" },
              { "value": "semi_annual", "label": "半年度（每6个月）" },
              { "value": "annual", "label": "年度（每12个月）" },
              { "value": "threshold", "label": "偏离触发（偏离>5%时）" }
            ]
          },
          {
            "id": "transaction_cost_tolerance",
            "label": "可接受的交易费用率(%)",
            "type": "percentage",
            "placeholder": "0.5",
            "required": false,
            "tooltip": "再平衡产生的交易费用最大可承受比例",
            "validation": {
              "min": 0,
              "max": 5,
              "type": "number"
            }
          }
        ]
      }
    ]
  },
  "field_types": {
    "currency": {
      "format": "currency",
      "decimalPlaces": 0,
      "prefix": "¥",
      "displayFormat": "#,##0"
    },
    "percentage": {
      "format": "percentage",
      "decimalPlaces": 1,
      "suffix": "%",
      "min": 0,
      "max": 100
    },
    "number": {
      "format": "number",
      "decimalPlaces": 0
    },
    "text": {
      "format": "text",
      "maxLength": 200
    },
    "select": {
      "format": "select",
      "multiple": false
    }
  },
  "validation_rules": {
    "fire_assessment": [
      {
        "rule": "total_assets >= total_liabilities",
        "message": "总资产必须大于等于总负债"
      },
      {
        "rule": "annual_savings >= 0",
        "message": "年储蓄能力不能为负"
      },
      {
        "rule": "annual_fixed_expenses > 0",
        "message": "年固定支出必须大于0"
      },
      {
        "rule": "monthly_mortgage_payment >= 0",
        "message": "房贷月供不能为负"
      }
    ],
    "dca_planning": [
      {
        "rule": "monthly_investment > 0",
        "message": "月投资金额必须大于0"
      },
      {
        "rule": "investment_target > monthly_investment * 12",
        "message": "投资目标应大于一年的投资总额"
      },
      {
        "rule": "investment_duration > 0",
        "message": "投资周期必须为正数"
      }
    ],
    "rebalancing": [
      {
        "rule": "current_stock_allocation + current_bond_allocation == 100",
        "message": "当前股票和债券配置之和必须等于100%"
      },
      {
        "rule": "target_stock_allocation + target_bond_allocation == 100",
        "message": "目标股票和债券配置之和必须等于100%"
      },
      {
        "rule": "portfolio_total_value > 0",
        "message": "投资组合总资产必须大于0"
      }
    ]
  }
}
